# Discord Bot Token — get from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Google Sheets credentials (path to JSON key file, or paste JSON content directly)
GOOGLE_SERVICE_ACCOUNT_JSON=path/to/your-service-account-key.json

# Google Sheet ID — the long string in the sheet's URL
# https://docs.google.com/spreadsheets/d/<THIS_IS_THE_ID>/edit
SHEET_ID=your_google_sheet_id_here

# Optional: AI categorization (leave blank to disable)
# OPENAI_API_KEY=sk-your-openai-key-here
